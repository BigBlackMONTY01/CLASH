# ── Clash Frontend — Environment Variables ──────────────────────────
#
# Copy this file to .env.local for local overrides.
# On Netlify, set these in Site Settings → Environment Variables.
#
# VITE_API_URL
#   Leave empty to use the Vite dev proxy (local development).
#   On Netlify, either:
#     (a) Leave empty and use netlify.toml to proxy /api/* (recommended), OR
#     (b) Set to your deployed API server URL, e.g.:
#         VITE_API_URL=https://your-api-server.replit.app
#
VITE_API_URL=
