modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_anthropic_ai_integrations:2.0.0", "javascript_database:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 20285
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "10fbc3f5b9f4b30dd27a99b2e32bcd1f43cb5709e584ad18486c51015c56f37d584b92f12dc1a29f76290b18e2128144cb6a4027b5efce8dd1a29485c35bf19d"
